MONGODB_URI=mongodb://localhost:27017/ShoppingCart
OPENROUTER_API_KEY=your_openrouter_api_key_here
JWT_SECRET=your_jwt_secret_key_here_change_in_production
PORT=5000

# Instructions:
# 1. Copy this file to .env
# 2. Replace 'your_openrouter_api_key_here' with your actual OpenRouter API key
# 3. Replace 'your_jwt_secret_key_here_change_in_production' with a secure JWT secret
